# Central routing for ALL projects on this server.
# Each project gets one block: a domain -> the project's web container.
# Caddy fetches + renews HTTPS for every domain automatically.
#
# Container names are "<compose-project>-<service>-1" by default, or whatever
# you set with `container_name`. The tg-search project's web container is
# reachable as "tgsearch-web" (see its docker-compose.shared.yml).

# --- Telegram Search Engine demo ---
tgsearch.example.com {
	encode gzip
	reverse_proxy tgsearch-web:3000
}

# --- Add future projects below, one block each ---
#
# project2.example.com {
# 	encode gzip
# 	reverse_proxy project2-web:3000
# }
