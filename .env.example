# Copy to .env and fill in. Never commit the real .env.

# Cloudflare account email — used for ACME/Let's Encrypt registration.
ACME_EMAIL=you@example.com

# Cloudflare API token (Zone.DNS edit permission, scoped to your domain) and
# the account email it belongs to. Used for DNS-01 challenge so Traefik can
# issue certs for wildcard/new subdomains without opening port 80 to ACME.
CF_API_EMAIL=you@example.com
CF_DNS_API_TOKEN=changeme
